{
  "name": "audio.transcriptions",
  "stack": "voice",
  "request": {
    "method": "POST",
    "path": "/v1/audio/transcriptions",
    "form": {
      "model": "whisper-1",
      "language": "en",
      "prompt": "domain words",
      "response_format": "verbose_json",
      "temperature": "0"
    },
    "files": [
      {"field": "file", "filename": "sample.wav", "content_base64": "ZmFrZSBhdWRpbyBieXRlcw==", "content_type": "audio/wav"}
    ]
  },
  "expect": {
    "status_code": 200,
    "paths": [
      {"path": "task", "equals": "transcribe"},
      {"path": "text", "equals": "hello from whisper"},
      {"path": "segments.0.start", "equals": 0.0}
    ]
  }
}
